; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Railhunter (钢轨猎人)"
config/description="A turn-based 2D pixel sci-fi RPG. Ride mechs, explore deep-space ruins, discover the truth one fragment at a time."
run/main_scene="res://src/main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

GameStateMachine="*res://src/autoload/game_state_machine.gd"
InputBus="*res://src/autoload/input_bus.gd"
ResourceRegistry="*res://src/autoload/resource_registry.gd"
MetaState="*res://src/autoload/meta_state.gd"
SaveManager="*res://src/autoload/save_manager.gd"
WeaponLoadout="*res://src/autoload/weapon_loadout.gd"
Inventory="*res://src/autoload/inventory.gd"
MechLoadout="*res://src/autoload/mech_loadout.gd"
ClinicManager="*res://src/autoload/clinic_manager.gd"
MechBayEvents="*res://src/ui/mech_bay_events.gd"
AutoModeAI="*res://src/autoload/auto_mode_ai.gd"
HallucinationManager="*res://src/autoload/hallucination_manager.gd"
AIEnemyManager="*res://src/autoload/ai_enemy_manager.gd"
BountyManager="*res://src/autoload/bounty_manager.gd"
RacingManager="*res://src/autoload/racing_manager.gd"
TerminalController="*res://src/autoload/terminal_controller.gd"
DialogueManager="*res://src/autoload/dialogue_manager.gd"
ResourceIntegrity="*res://src/autoload/resource_integrity.gd"
SFXPlayer="*res://src/autoload/sfx_player.gd"
MusicPlayer="*res://src/autoload/music_player.gd"
AudioManager="*res://src/autoload/audio_manager.gd"
ParticleFx="*res://src/autoload/particle_fx.gd"
ReplayRecorder="*res://src/autoload/replay_recorder.gd"
SpeedrunTimer="*res://src/autoload/speedrun_timer.gd"
Localization="*res://src/autoload/localization.gd"
EndingController="*res://src/autoload/ending_controller.gd"
QuestManager="*res://src/autoload/quest_manager.gd"
TutorialManager="*res://src/autoload/tutorial_manager.gd"
DeathScreen="*res://src/ui/death_screen.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[gui]

theme/custom = ExtResource("uid://rh_default_theme")

[dotnet]

project/assembly_name="Railhunter"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

