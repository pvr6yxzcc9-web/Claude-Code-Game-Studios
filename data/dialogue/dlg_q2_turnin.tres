[gd_resource type="Resource" script_class="DialogueTree" load_steps=2 format=3 uid="uid://dlg_q2_turnin"]

[ext_resource type="Script" path="res://src/resource/dialogue_tree.gd" id="1_dlg"]

[resource]
script = ExtResource("1_dlg")
id = &"dlg_q2_turnin"
start_node_id = &"q2_start"
nodes = {
&"q2_start": {
"text": "Ice Hermit's Relic\n\nThe hermit guards a pre-Rift artifact. She says it belonged to her family. The Black Market pays 3000 gold for one.",
"choices": [
{"label": "[1] We sit with her. Hear the story. Leave the artifact where it is. (Compassionate)", "next": &"q2_comp_end"},
{"label": "[2] We offer her 1500 gold. Half of market value, but she keeps it. (Pragmatic)", "next": &"q2_prag_end"},
{"label": "[3] We steal it at night. Sell to the Black Market. The hermit never knows. (Ruthless)", "next": &"q2_ruth_end"},
]
},
&"q2_comp_end": {
"text": "You chose compassion. The NPC accepts your decision. Quest complete. (truth +1)",
"unlock_fragment_id": &"quest_q2_truth_compassionate",
"choices": []
},
&"q2_prag_end": {
"text": "You chose pragmatism. The NPC accepts your decision. Quest complete. (truth 0)",
"choices": []
},
&"q2_ruth_end": {
"text": "You chose ruthlessness. The NPC accepts your decision. Quest complete. (truth -1)",
"unlock_fragment_id": &"quest_q2_truth_ruthless",
"choices": []
},
}
