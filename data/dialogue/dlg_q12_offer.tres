&"q12_start": {
"text": "??? (Post-Game)\n\nThe post-game courier stands at the edge of the chamber. They have one more truth. Are you ready?",
"choices": [
{"label": "[1] We listen. The final truth is gentle. (Compassionate)", "next": &"q12_comp_end"},
{"label": "[2] We listen. The final truth is honest. (Pragmatic)", "next": &"q12_prag_end"},
{"label": "[3] We refuse. Some truths are too heavy. (Ruthless)", "next": &"q12_ruth_end"},
]
},
&"q12_comp_end": {
"text": "You chose compassion. The NPC accepts your decision. Quest complete. (truth +1)",
