[gd_resource type="Resource" script_class="DialogueTree" load_steps=2 format=3 uid="uid://dlg_scavenger_leader_001"]

[ext_resource type="Script" path="res://src/resource/dialogue_tree.gd" id="1_dlg"]

[resource]
script = ExtResource("1_dlg")
id = &"dlg_scavenger_leader"
start_node_id = &"scavenger_leader"
nodes = {
&"scavenger_leader": {"text": "I run the crew. We take from the dead and give to the living. The warden is alive, technically. We don't bother her. She bothers us. The crates you want are the ones we don't touch.", "choices": [{"label": "Continue", "next": "followup"}]},
&"followup": {"text": "[{'label': "What's in the crates?", 'next': 'crates'}]"},
}
