[gd_resource type="Resource" script_class="DialogueTree" load_steps=2 format=3 uid="uid://dlg_frost_engineer_001"]

[ext_resource type="Script" path="res://src/resource/dialogue_tree.gd" id="1_dlg"]

[resource]
script = ExtResource("1_dlg")
id = &"dlg_frost_engineer"
start_node_id = &"frost_engineer"
nodes = {
&"frost_engineer": {"text": "The cryo-chamber must be cold. The family inside must sleep. If you wake them, you kill them. If you let them sleep, they die anyway. There is no good answer. I am the engineer. I keep the cold.", "choices": [{"label": "Continue", "next": "followup"}]},
&"followup": {"text": "[{'label': 'Who is in the chamber?', 'next': 'chamber'}]"},
}
