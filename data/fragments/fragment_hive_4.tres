[gd_resource type="Resource" script_class="StoryFragmentData" load_steps=2 format=3 uid="uid://fragment_hive_4_001"]

[ext_resource type="Script" path="res://src/resource/story_fragment_data.gd" id="1_frag"]

[resource]
script = ExtResource("1_frag")
id = &"fragment_hive_4"
title = "蜂后的低语 (The Queen's Whisper)"
body = "The queen is not the hive's queen. She is the hive's tongue. When she speaks, the Creator is speaking through her. I heard her. She said: 'We are not invaders. We are the inheritance. The first life on every world. We are what comes before. We are what waits.'"
unlock_condition = &"defeated_boss_hive_queen_guardian"
related_fragment_ids = Array[StringName]([&"fragment_hive_1", &"fragment_hive_5"])
lore_layer = 7
