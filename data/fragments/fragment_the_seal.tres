[gd_resource type="Resource" script_class="StoryFragmentData" load_steps=2 format=3 uid="uid://fragment_the_seal_001"]

[ext_resource type="Script" path="res://src/resource/story_fragment_data.gd" id="1_frag"]

[resource]
script = ExtResource("1_frag")
id = &"fragment_the_seal"
title = "The Seal"
body = "The engine room was the last to lose power. The seal on the cargo hold is mechanical — a heavy bolt, not electronics. Marlow's last note before she stopped writing was that she'd 'closed the door from the inside'. The only way to open it now is to cut the bolt. Cutting the bolt means losing atmosphere on every level below. The seal has held for fifty years because nobody has been willing to pay that price. Not the salvage crews. Not the drones. Not the ones who came before you."
unlock_condition = &"read_log_engine_room_note"
related_fragment_ids = Array[StringName]([&"fragment_marlows_daughter", &"fragment_what_was_carried"])
lore_layer = 4
