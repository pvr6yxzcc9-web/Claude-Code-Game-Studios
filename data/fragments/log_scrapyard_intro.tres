[gd_resource type="Resource" script_class="TerminalLogData" load_steps=2 format=3 uid="uid://log_scrapyard_intro_001"]

[ext_resource type="Script" path="res://src/resource/terminal_log_data.gd" id="1_log"]

[resource]
script = ExtResource("1_log")
id = &"log_scrapyard_intro"
title = "JOURNAL ENTRY 0042"
body = "The reactor's gone cold. Three weeks since the Rift pulled us out of the convoy. We were supposed to make the trade at Nexus-7, but the navigation's wrecked and the comm array's just static. I've sealed off the lower decks — something's moving down there, and I don't think it's the salvage drones anymore. If anyone finds this, the access code to the cargo bay is my daughter's birthday. Don't open it unless you mean it."
author = "Engineer V. K. Marlow"
date_in_world = "Cycle 421.03"
unlock_fragment_id = &"fragment_who_we_were"
importance = 3
