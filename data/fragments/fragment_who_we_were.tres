[gd_resource type="Resource" script_class="StoryFragmentData" load_steps=2 format=3 uid="uid://fragment_who_we_were_001"]

[ext_resource type="Script" path="res://src/resource/story_fragment_data.gd" id="1_frag"]

[resource]
script = ExtResource("1_frag")
id = &"fragment_who_we_were"
title = "Who We Were"
body = "The convoy was family once. Engineer Marlow sealed the cargo bay with a personal code, not a military one. Whatever is in there, she wanted it kept safe — or kept hidden. Either way, the answer to 'who were we before the Rift' is locked behind her daughter's birthday."
unlock_condition = &"read_log_scrapyard_intro"
related_fragment_ids = Array[StringName]([])
lore_layer = 1
