[gd_resource type="Resource" script_class="StoryFragmentData" load_steps=2 format=3 uid="uid://fragment_hive_6_001"]

[ext_resource type="Script" path="res://src/resource/story_fragment_data.gd" id="1_frag"]

[resource]
script = ExtResource("1_frag")
id = &"fragment_hive_6"
title = "繁殖的意义 (The Purpose of Breeding)"
body = "The breeders do not breed for population. They breed for variety. Each larva is unique, a slightly different neuron in the hive's distributed mind. The hive is not a colony. It is a symphony. Each creature is a note. The queen is the conductor. The Creator is the composer. We are the audience."
unlock_condition = &"defeated_breeder_miniboss"
related_fragment_ids = Array[StringName]([&"fragment_hive_2", &"fragment_hive_4"])
lore_layer = 7
