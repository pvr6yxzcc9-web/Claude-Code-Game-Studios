[gd_resource type="Resource" script_class="StoryFragmentData" load_steps=2 format=3 uid="uid://fragment_marlows_daughter_001"]

[ext_resource type="Script" path="res://src/resource/story_fragment_data.gd" id="1_frag"]

[resource]
script = ExtResource("1_frag")
id = &"fragment_marlows_daughter"
title = "Marlow's Daughter"
body = "Vera Marlow. Eight years old when the convoy lifted. She was supposed to be at the academy dormitory on Nexus-7 when the Rift took us — not in the cargo hold. But her mother sealed the hold with a personal code, not a military one. A birthday. The only one that would never be brute-forced by the salvage crews. The engineers who cracked the upper decks never found the hold. The lower decks — 'the convoy' — are where she would have been, if she survived the transfer. If she survived at all."
unlock_condition = &"read_log_personal_log"
related_fragment_ids = Array[StringName]([&"fragment_the_convoy", &"fragment_the_seal"])
lore_layer = 3
