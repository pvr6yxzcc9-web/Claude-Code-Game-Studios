[gd_resource type="Resource" script_class="StoryFragmentData" load_steps=2 format=3 uid="uid://fragment_the_truth_001"]

[ext_resource type="Script" path="res://src/resource/story_fragment_data.gd" id="1_frag"]

[resource]
script = ExtResource("1_frag")
id = &"fragment_the_truth"
title = "The Truth"
body = "If the lower decks are opened, the cargo will be found. The cargo is people. The forty-two couriers did not survive the transfer. Their bodies, preserved by the hold's atmosphere, are the cargo. The convoy was carrying the dead home. The Rift took the convoy before it could deliver them. The seal was not Marlow's idea — it was the convoy's. The dead are not weapons. They are the last family the convoy had."
unlock_condition = &"boss_victory"
related_fragment_ids = Array[StringName]([&"fragment_what_was_carried"])
lore_layer = 6
