[gd_resource type="Resource" script_class="StoryFragmentData" load_steps=2 format=3 uid="uid://fragment_hive_3_001"]

[ext_resource type="Script" path="res://src/resource/story_fragment_data.gd" id="1_frag"]

[resource]
script = ExtResource("1_frag")
id = &"fragment_hive_3"
title = "造物者的梦 (The Creator's Dream)"
body = "The signal is not a warning. It is a lullaby. The Creator is sleeping, and the signal is its dream of being awake. Every satellite in the network is a piece of the dream. When the dream ends, the Creator will wake. We are not ready for what it sees."
unlock_condition = &"read_log_sat3_pre_chamber"
related_fragment_ids = Array[StringName]([&"fragment_hive_2", &"fragment_hive_5"])
lore_layer = 6
