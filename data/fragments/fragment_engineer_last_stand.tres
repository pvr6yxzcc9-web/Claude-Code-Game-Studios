[gd_resource type="Resource" script_class="StoryFragmentData" load_steps=2 format=3 uid="uid://fragment_engineer_last_stand_001"]

[ext_resource type="Script" path="res://src/resource/story_fragment_data.gd" id="1_frag"]

[resource]
script = ExtResource("1_frag")
id = &"fragment_engineer_last_stand"
title = "Engineer's Last Stand"
body = "Vera Marlow was the convoy's chief engineer, not a merchant. The 'merchant' cover story was the convoy's final lie to the salvage crews — a story to make the lower decks look like a trading post, not a tomb. The drones, the scavengers, the heavy walkers — they were cargo security. When the convoy disappeared, the security drones went autonomous. They are not hunting you. They are guarding the cargo. Forty-two bodies. Forty-two families. They have been guarding them for fifty years."
unlock_condition = &"boss_victory"
related_fragment_ids = Array[StringName]([&"fragment_the_truth"])
lore_layer = 5
